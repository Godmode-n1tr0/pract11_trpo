<Application x:Class="pract7.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:pract7.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:AgeConverter x:Key="AgeConverter"/>
            <converters:PhoneNumberConverter x:Key="PhoneNumberConverter"/>
            <converters:DaysSinceLastAppointmentConverter x:Key="DaysSinceLastAppointmentConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>